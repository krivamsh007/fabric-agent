# Fabric Agent — Environment Configuration Template
# ==================================================
# Copy this file to .env and fill in your own values.
# IMPORTANT: .env is git-ignored. Never commit real credentials.
#
#   cp .env.template .env      (macOS / Linux)
#   copy .env.template .env    (Windows CMD)
#
# See docs/PREREQUISITES.md for step-by-step setup instructions.

# ── Azure AD / Entra ID ───────────────────────────────────────────────────────
# Your Azure Tenant GUID.
# Portal: https://portal.azure.com → Azure Active Directory → Overview
AZURE_TENANT_ID=

# Service Principal (App Registration) Client ID.
# Portal: Azure Active Directory → App Registrations → your app → Application (client) ID
AZURE_CLIENT_ID=

# Service Principal Client Secret.
# Portal: Azure Active Directory → App Registrations → your app → Certificates & secrets
# SECURITY: Rotate this value immediately if it is ever accidentally exposed.
AZURE_CLIENT_SECRET=

# Authentication mode.
# Set to "false" to use service principal (ClientSecretCredential).
# Set to "true" to use interactive browser login (for local dev without a secret).
USE_INTERACTIVE_AUTH=false

# ── Microsoft Fabric ─────────────────────────────────────────────────────────
# OAuth scope for the Fabric REST API (leave as-is unless you have a custom cloud).
FABRIC_SCOPES=https://api.fabric.microsoft.com/.default

# Human-readable workspace name used by bootstrap scripts.
FABRIC_WORKSPACE_NAME=

# Human-readable capacity name ("Trial", "F64-Prod", etc.).
FABRIC_CAPACITY_NAME=Trial

# Capacity GUID — required when creating Lakehouses and Notebooks.
# Run:  python scripts/list_capacities.py   to discover your capacity GUIDs.
FABRIC_CAPACITY_ID=

# Require capacity assignment before provisioning items (recommended: true).
FABRIC_REQUIRE_CAPACITY=true

# ── Optional: Report template ─────────────────────────────────────────────────
# If you want bootstrap to create Reports by cloning a known-good template:
# FABRIC_REPORT_TEMPLATE_ID=<report-item-guid>
# FABRIC_REPORT_TEMPLATE_WORKSPACE_ID=<workspace-guid-containing-template>

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Which LLM powers the OrchestratorLLMAgent.
# "ollama"       → fully local, zero API key needed (DEFAULT — install Ollama + pull model)
# "claude"       → Anthropic Claude (best reasoning quality, requires API key below)
# "azure_openai" → Azure OpenAI (enterprise, same DefaultAzureCredential as Fabric)
LLM_PROVIDER=ollama

# ── Ollama (DEFAULT — no API key needed) ─────────────────────────────────────
# Install: https://ollama.ai  (Windows / Mac / Linux — one-click)
# Pull model: ollama pull llama3.1        (8B, good tool-calling, fast on CPU)
#             ollama pull qwen2.5:14b     (14B, stronger reasoning)
#             ollama pull mistral         (7B, fast, good tool-calling)
#
# Ollama starts automatically after install; change URL if hosting remotely.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Claude / Anthropic (optional, best reasoning quality) ────────────────────
# Enable: set LLM_PROVIDER=claude and fill in your key.
# Get key: https://console.anthropic.com → API Keys
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Azure OpenAI (optional, enterprise — uses DefaultAzureCredential) ─────────
# Enable: set LLM_PROVIDER=azure_openai and fill in endpoint + deployment.
# Uses the same az login / managed identity as FabricApiClient — no extra key needed.
# AZURE_OPENAI_ENDPOINT=https://my-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_KEY=    # Leave empty to use managed identity / az login

# ── Resilience (retry + circuit breaker) ─────────────────────────────────────
# All Fabric REST API calls go through RetryPolicy + CircuitBreaker automatically.
# Change only if you need to tune for unusually slow or flaky environments.
# FABRIC_AGENT_MAX_RETRIES=3                     # Retry attempts on 429/5xx
# FABRIC_AGENT_CIRCUIT_BREAKER_THRESHOLD=5       # Failures before circuit opens
# FABRIC_AGENT_CIRCUIT_BREAKER_RESET_SECONDS=60  # Seconds before retry probe

# ── Agent behaviour ───────────────────────────────────────────────────────────
# Log level for the agent (DEBUG, INFO, WARNING, ERROR)
# FABRIC_AGENT_LOG_LEVEL=INFO

# Storage backend for audit trail (default: sqlite)
# FABRIC_AGENT_STORAGE_BACKEND=sqlite
# FABRIC_AGENT_STORAGE_PATH=./data/fabric_agent.db

# Enable the Impact Analysis agent (set to "1" to activate real-time impact scoring)
AGENT_IMPACT_ENABLED=1

# Enable the local agent when the fabric_agent wheel is installed in a Fabric notebook.
# The bootstrap sets this automatically when the wheel is found — leave as "0" here.
LOCAL_AGENT_ENABLED=0

# Stop pipeline immediately if a BREAKING schema drift is detected (recommended: "0" in dev)
BREAK_ON_BREAKING_DRIFT=0

# ── Email alerts (Gmail SMTP) ─────────────────────────────────────────────────
# The notebooks send an email alert when a breaking schema drift or healing action occurs.
# Leave blank to disable email alerts.
#
# Gmail setup (requires a Gmail App Password, not your regular password):
#   Google Account → Security → 2-Step Verification → App passwords → Generate
SMTP_USER=
SMTP_PASSWORD=

# Comma-separated list of alert recipients (defaults to SMTP_USER if left blank)
ALERT_EMAIL_TO=

# SMTP server settings — defaults below work for Gmail; change for other providers
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── OneLake seed upload ────────────────────────────────────────────────────────
# Set to "1" to have bootstrap scripts upload synthetic CSVs via the OneLake DFS API.
# Set to "0" if you prefer to upload seed files manually (see README §3 Seed data).
ONE_LAKE_UPLOAD=1
